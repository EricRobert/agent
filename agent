#!/usr/bin/env bash

BASENAME=$(basename "$0")
if [[ "$BASENAME" != "agent" ]]; then
    AGENT="$BASENAME"
else
    AGENT="${1:-}"
    if [[ $# -gt 0 ]]; then
        shift
    fi
fi

UPDATE_VERSION=
if [[ "${1:-}" == "--update" ]]; then
    shift
    UPDATE_VERSION="${1:-}"
    if [[ -z "$UPDATE_VERSION" ]]; then
        echo "--update requires a version"
        exit 1
    fi
    shift
fi

AGENT_ARGS=("$@")

if [ -z "$AGENT" ]; then
    echo "Usage: agent {claude|codex|gemini|kiro|opencode} [--update VERSION] [args...]"
    exit 1
fi

case "$AGENT" in
    claude|codex|gemini|kiro|opencode) ;;
    *)
        echo "Unknown agent: $AGENT"
        echo "Supported agents: claude, codex, gemini, kiro, opencode"
        exit 1
        ;;
esac

IMAGE="agent-cli:$AGENT"
CONTEXT="$PWD"

if [[ -n "$UPDATE_VERSION" ]]; then
    VERSION_ARG="$(echo "$AGENT" | tr '[:lower:]' '[:upper:]')_VERSION"

    docker build \
        --pull \
        --target "$AGENT" \
        --build-arg UID=$(id -u) \
        --build-arg GID=$(id -g) \
        --build-arg USERNAME=$USER \
        --build-arg "$VERSION_ARG=$UPDATE_VERSION" \
        -t "$IMAGE" "$CONTEXT"
fi

mkdir -p "$HOME/.npm" "$HOME/.cache/uv" "$HOME/.cache/go-build" "$HOME/.go/pkg/mod"

MOUNTS=(
    -v "$HOME/.npm:/home/$USER/.npm"
    -v "$HOME/.cache/uv:/home/$USER/.cache/uv"
    -v "$HOME/.cache/go-build:/home/$USER/.cache/go-build"
    -v "$HOME/.go/pkg/mod:/home/$USER/.go/pkg/mod"
    -v "$PWD:/home/$USER/workspace"
)

ROOT=".$AGENT"

case "$AGENT" in
    kiro)
        mkdir -p "$HOME/.aws" "$HOME/.local/share/kiro-cli"
        MOUNTS+=(-v "$HOME/.aws:/home/$USER/.aws")
        MOUNTS+=(-v "$HOME/.local/share/kiro-cli:/home/$USER/.local/share/kiro-cli")
        ;;
    opencode)
        mkdir -p "$HOME/.local/share/opencode" "$HOME/.config/opencode"
        MOUNTS+=(-v "$HOME/.local/share/opencode:/home/$USER/.local/share/opencode")
        ROOT=.config/opencode
        ;;
esac

MOUNTS+=(-v "$CONTEXT/agents/$AGENT:/home/$USER/$ROOT")

for skill in "$CONTEXT"/skills/*/; do
    [ -d "$skill" ] && MOUNTS+=(-v "$skill:/home/$USER/$ROOT/skills/$(basename "$skill")")
done

ENV_VARS=(
    ANTHROPIC_API_KEY
    GEMINI_API_KEY
    KIRO_API_KEY
    OPENAI_API_KEY
    OPENROUTER_API_KEY
    TERM
    COLORTERM
)

ENV_ARGS=(-e BROWSER=echo)
for NAME in "${ENV_VARS[@]}"; do
    if [ -n "${!NAME+x}" ]; then
        ENV_ARGS+=(-e "$NAME")
    fi
done

docker run --rm -ti --net host \
    "${MOUNTS[@]}" \
    "${ENV_ARGS[@]}" \
    "$IMAGE" "$AGENT" "${AGENT_ARGS[@]}"
