{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/qwen3-coder-next",
  "permission": "allow",
  "provider": {
    "openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp",
      "options": {
        "baseURL": "http://localhost:8080/v1",
        "timeout": 120000,
        "temperature": 0.7
      },
      "models": {
        "qwen3-coder-next": {
          "name": "qwen3-coder-next",
          "limit": {
            "context": 65535,
            "output": 32768
          }
        },
        "deepseek-coder-v2": {
          "name": "deepseek-coder-v2",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        }
      }
    }
  }
}